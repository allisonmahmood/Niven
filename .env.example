PLAID_CLIENT_ID=
PLAID_SECRET=

# Required for this sandbox-only build.
PLAID_ENV=sandbox

# Optional: defaults to US if omitted.
# PLAID_COUNTRY_CODES=US

# Optional: leave commented out unless you want to override products.
# PLAID_PRODUCTS=transactions,investments,transfer

# Optional: local API auth token. If set, callers must send `Authorization: Bearer <token>`.
# NIVEN_API_TOKEN=

# Optional: defaults shown below.
# NIVEN_API_HOST=127.0.0.1
# NIVEN_API_PORT=4321
# NIVEN_DATA_DIR=.niven
# NIVEN_REQUIRE_MUTATION_APPROVAL=false
