{
  "name": "niven",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "biome lint --error-on-warnings .",
    "format": "biome format --write .",
    "check": "biome check --error-on-warnings .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "verify": "pnpm check && pnpm typecheck && pnpm test",
    "verify:env": "node --env-file-if-exists=.env scripts/verify-env.mjs",
    "api:dev": "pnpm --filter @niven/wealth-api dev",
    "api:start": "pnpm --filter @niven/wealth-api start",
    "sandbox:bootstrap-user": "pnpm --filter @niven/wealth-api sandbox:bootstrap",
    "sandbox:add-checking": "pnpm --filter @niven/wealth-api sandbox:payday",
    "sandbox:payday": "pnpm --filter @niven/wealth-api sandbox:payday",
    "sandbox:reset-from-plaid": "pnpm --filter @niven/wealth-api sandbox:reset-from-plaid",
    "harness:chat": "pnpm --filter @niven/harness-cli chat",
    "harness:login": "pnpm --filter @niven/harness-cli login",
    "harness:prompt": "pnpm --filter @niven/harness-cli prompt"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,jsx,tsx,json,jsonc}": [
      "biome check --write --error-on-warnings --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "25.5.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  }
}
