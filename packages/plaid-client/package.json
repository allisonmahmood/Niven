{
  "name": "@niven/plaid-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox.d.ts",
      "default": "./dist/sandbox.js"
    },
    "./items": {
      "types": "./dist/items.d.ts",
      "default": "./dist/items.js"
    },
    "./investments": {
      "types": "./dist/investments.d.ts",
      "default": "./dist/investments.js"
    },
    "./transactions": {
      "types": "./dist/transactions.d.ts",
      "default": "./dist/transactions.js"
    },
    "./transfers": {
      "types": "./dist/transfers.d.ts",
      "default": "./dist/transfers.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --build tsconfig.json",
    "test": "pnpm exec vitest run tests"
  },
  "dependencies": {
    "@niven/shared": "workspace:*",
    "plaid": "41.4.0"
  }
}
